{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --session-end"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --subagent-start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --subagent-stop"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --worktree-create-hook"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --worktree-remove"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --file-changed"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --cwd-changed"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --pre-compact"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --release"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python /home/ilari/Software/Repositories/Lomitus/lomitus/coordinator.py --failure"
          }
        ]
      }
    ]
  }
}
